# BookNow Dashboard — environment variables
# Copy this file to .env and fill in your values.

# ── Dashboard server ────────────────────────────────────────────────
PORT=3000

# ── Redis (must match python-engine's REDIS_HOST/REDIS_PORT) ────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Binance credentials ────────────────────────────────────────────
# The dashboard's binance-worker uses these for the listenKey lifecycle
# and the !miniTicker WS cache. The python-engine reads the same keys
# (the engine loads dashboard/.env in addition to python-engine/.env).
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ── python-engine API ──────────────────────────────────────────────
# Where the dashboard finds the engine's HTTP API. Defaults to
# http://localhost:8083/api/v1; override if the engine runs elsewhere
# (e.g. behind a reverse proxy).
# BOOKNOW_ENGINE_BASE=http://localhost:8083/api/v1
# BOOKNOW_ENGINE_PORT=8083

# Picks the python interpreter for `POST /api/service/start` to spawn.
# Order tried: $BOOKNOW_PYTHON → ../venv313/bin/python →
# ../venv/bin/python → python3 (PATH).
# BOOKNOW_PYTHON=

# ── Auto-trade UI defaults (the dashboard form overrides these live) ─
DEFAULT_PROFIT_PCT=1.5
DEFAULT_STOP_LOSS_PCT=0.8
DEFAULT_MAX_POSITIONS=5
DEFAULT_DISPLAY_LIMIT=10
DEFAULT_SIMULATION_MODE=true
